# ============================================================================
# Elite Tools — Environment Variables
# ============================================================================
# Copy to .env.local and fill in. Never commit .env.local.

# ----------------------------------------------------------------------------
# Convex — the CRM database
# ----------------------------------------------------------------------------
# Run `npx convex dev` once to create a deployment. It will write
# CONVEX_DEPLOYMENT here automatically and give you the public URL below.

CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ----------------------------------------------------------------------------
# Clerk — authentication
# ----------------------------------------------------------------------------
# Create a Clerk application at https://dashboard.clerk.com
# Copy the two keys from the "API Keys" tab.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ----------------------------------------------------------------------------
# Clerk <> Convex integration
# ----------------------------------------------------------------------------
# In Clerk dashboard: JWT Templates -> New template -> Convex.
# Copy the "Issuer" URL and paste below.
# Convex's auth.config.ts reads this at deploy time.

CLERK_JWT_ISSUER_DOMAIN=

# ----------------------------------------------------------------------------
# Optional: Clerk post-sign-in redirect
# ----------------------------------------------------------------------------
# Leave as default unless you have a reason to change.

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ----------------------------------------------------------------------------
# Email marketing — planned, not yet implemented
# ----------------------------------------------------------------------------
# Centralised email-marketing platform for all ELC brands (planned replacement
# for Acteol's email side). Vendor not yet chosen — strongest default is
# Resend (already in the customer-site stack for transactional, supports
# Audiences + Broadcasts on the same API key). Keep blank until selected.

EMAIL_MARKETING_PROVIDER=
EMAIL_MARKETING_API_KEY=

# Per-brand mailing-list IDs (Resend Audience IDs or equivalent)
EMAIL_MARKETING_AUDIENCE_OWP=
EMAIL_MARKETING_AUDIENCE_SALOMONS=
EMAIL_MARKETING_AUDIENCE_BEWL_WATER=
EMAIL_MARKETING_AUDIENCE_BEWL_ADVENTURES=
EMAIL_MARKETING_AUDIENCE_CHRISTMAS_AT_BEWL=

# Per-brand default sender ("from" address). Format: "Display Name <addr@domain>"
EMAIL_MARKETING_FROM_OWP=
EMAIL_MARKETING_FROM_SALOMONS=
EMAIL_MARKETING_FROM_BEWL_WATER=
EMAIL_MARKETING_FROM_BEWL_ADVENTURES=
EMAIL_MARKETING_FROM_CHRISTMAS_AT_BEWL=
